# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# IDEs
/.vscode/
/.idea/

# bun
bun.lockb
.bun

# Prisma generated client / runtime files
/prisma/client
/node_modules/.prisma

# local DB files
*.db
*.sqlite
*.sqlite3

# caches and build outputs
.cache
.turbo
/dist

# other logs
pnpm-debug.log*
server.log
